### ==========================================
### 1. SETUP: CREATE MULTIPLE USERS
### ==========================================

### Register User 1 (The Teacher)
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "email": "teacher@nexuslearn.com",
  "password": "password123",
  "firstName": "Ada",
  "lastName": "Lovelace"
}

### Login User 1 -> Save Token
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "email": "teacher@nexuslearn.com",
  "password": "password123"
}

> {%
    client.global.set("teacher_token", response.body.accessToken);
%}

### Register User 2 (The Assistant)
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "email": "assistant@nexuslearn.com",
  "password": "password123",
  "firstName": "Alan",
  "lastName": "Turing"
}

### Register User 3 (The Student)
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "email": "student@nexuslearn.com",
  "password": "password123",
  "firstName": "Grace",
  "lastName": "Hopper"
}

### Register User 4 (The hacker)
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "email": "hacker@nexuslearn.com",
  "password": "password123",
  "firstName": "Eve",
  "lastName": "Malory"
}

### Login User 4 -> Save Hacker Token
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "email": "hacker@nexuslearn.com",
  "password": "password123"
}

> {%
    client.global.set("hacker_token", response.body.accessToken);
%}


### ==========================================
### 2. COURSE CREATION & MEMBER ASSIGNMENT
### ==========================================

### Teacher creates a Course -> Save Course ID
POST http://localhost:8080/api/courses
Content-Type: application/json
Authorization: Bearer {{teacher_token}}

{
  "title": "Cryptography 101",
  "description": "Learn to break the Enigma."
}

> {%
    // This extracts the UUID from the JSON response and saves it
    client.global.set("course_id", response.body.id);
%}

### Teacher adds Alan as an ASSISTANT
POST http://localhost:8080/api/courses/{{course_id}}/members
Content-Type: application/json
Authorization: Bearer {{teacher_token}}

{
  "email": "assistant@nexuslearn.com",
  "role": "ASSISTANT"
}

### Teacher adds Grace as a STUDENT
POST http://localhost:8080/api/courses/{{course_id}}/members
Content-Type: application/json
Authorization: Bearer {{teacher_token}}

{
  "email": "student@nexuslearn.com",
  "role": "STUDENT"
}


### ==========================================
### 3. THE SECURITY TESTS
### ==========================================

### Hacker tries to add themselves to the course as a STUDENT
### EXPECTED RESULT: HTTP 500 (Access Denied)
POST http://localhost:8080/api/courses/{{course_id}}/members
Content-Type: application/json
Authorization: Bearer {{hacker_token}}

{
  "email": "hacker@nexuslearn.com",
  "role": "STUDENT"
}

### Hacker tries to add themselves to the course as an ADMIN
### EXPECTED RESULT: HTTP 500 (Access Denied)
POST http://localhost:8080/api/courses/{{course_id}}/members
Content-Type: application/json
Authorization: Bearer {{hacker_token}}

{
  "email": "hacker@nexuslearn.com",
  "role": "ADMIN"
}